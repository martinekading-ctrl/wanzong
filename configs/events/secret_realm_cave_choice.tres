[gd_resource type="Resource" script_class="EventDefinition" load_steps=2 format=3]
[ext_resource type="Script" path="res://scripts/data/EventDefinition.gd" id="1"]
[resource]
script = ExtResource("1")
id = "secret_realm_cave_choice"
title = "玄石古洞：残破禁制"
description = "古洞深处的禁制仍在运转，绕行安全，强行破阵则可能发现遗藏。"
category = "world"
trigger = {"result": "success", "type": "mission_result"}
conditions = [{"key": "secret_realm_id", "operator": "==", "type": "context", "value": "secret_realm_ancient_cave"}]
options = [{"costs": {"spirit_stone": 20}, "effects": [{"progress": 1, "rewards": {"spirit_ore": 35}, "type": "secret_realm_exploration"}], "id": "dispel", "label": "稳妥解禁", "result_text": "队伍消耗灵石化解禁制，带回了灵矿。"}, {"costs": {}, "effects": [{"health_loss": 18, "injury_chance": 0.5, "progress": 1, "rewards": {"spirit_ore": 70, "spirit_stone": 60}, "type": "secret_realm_exploration"}], "id": "break", "label": "强行破阵", "result_text": "禁制反噬造成伤势，但遗藏更为丰厚。"}]
trigger_once = false

