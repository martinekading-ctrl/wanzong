[gd_resource type="Resource" script_class="EventDefinition" load_steps=2 format=3]
[ext_resource type="Script" path="res://scripts/data/EventDefinition.gd" id="1"]
[resource]
script = ExtResource("1")
id = "secret_realm_misty_choice"
title = "雾隐灵谷：岔路"
description = "灵雾中出现两条道路：一条灵气温和，另一条传来异兽低吼。"
category = "world"
trigger = {"result": "success", "type": "mission_result"}
conditions = [{"key": "secret_realm_id", "operator": "==", "type": "context", "value": "secret_realm_misty_valley"}]
options = [{"costs": {}, "effects": [{"progress": 1, "rewards": {"spirit_grass": 20}, "type": "secret_realm_exploration"}], "id": "safe_path", "label": "沿灵气前进", "result_text": "队伍稳步深入，并采集到一批灵草。"}, {"costs": {}, "effects": [{"health_loss": 12, "injury_chance": 0.35, "progress": 1, "rewards": {"spirit_grass": 45, "spirit_stone": 30}, "type": "secret_realm_exploration"}], "id": "beast_path", "label": "追寻异兽", "result_text": "队伍冒险突破兽群，取得更多收获。"}, {"costs": {}, "effects": [{"progress": 0, "rewards": {}, "type": "secret_realm_exploration"}], "id": "withdraw", "label": "谨慎撤回", "result_text": "队伍保存实力，暂时退出秘境。"}]
trigger_once = false

