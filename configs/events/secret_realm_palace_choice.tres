[gd_resource type="Resource" script_class="EventDefinition" load_steps=2 format=3]
[ext_resource type="Script" path="res://scripts/data/EventDefinition.gd" id="1"]
[resource]
script = ExtResource("1")
id = "secret_realm_palace_choice"
title = "坠星遗宫：星辉大殿"
description = "破败大殿中星辉流转，正殿机缘惊人，偏殿则相对安全。"
category = "world"
trigger = {"result": "success", "type": "mission_result"}
conditions = [{"key": "secret_realm_id", "operator": "==", "type": "context", "value": "secret_realm_fallen_palace"}]
options = [{"costs": {"spirit_stone": 50}, "effects": [{"progress": 1, "rewards": {"spirit_grass": 30, "spirit_ore": 50}, "type": "secret_realm_exploration"}], "id": "side_hall", "label": "探索偏殿", "result_text": "队伍避开核心禁制，在偏殿取得稳定收获。"}, {"costs": {}, "effects": [{"health_loss": 25, "injury_chance": 0.7, "progress": 1, "rewards": {"spirit_grass": 60, "spirit_ore": 100, "spirit_stone": 120}, "type": "secret_realm_exploration"}], "id": "main_hall", "label": "闯入正殿", "result_text": "队伍承受星辉冲击，夺得大殿中的珍藏。"}]
trigger_once = false
