; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="WanZong"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SceneManager="*res://scripts/managers/SceneManager.gd"
WorldDataManager="*res://scripts/managers/WorldDataManager.gd"
SectManager="*res://scripts/managers/SectManager.gd"
DiscipleManager="*res://scripts/managers/DiscipleManager.gd"
EconomyManager="*res://scripts/managers/EconomyManager.gd"
GameHistoryManager="*res://scripts/managers/GameHistoryManager.gd"
BreakthroughManager="*res://scripts/managers/BreakthroughManager.gd"
EventManager="*res://scripts/managers/EventManager.gd"
AISimulationManager="*res://scripts/managers/AISimulationManager.gd"
ConstructionManager="*res://scripts/managers/ConstructionManager.gd"
ModifierManager="*res://scripts/managers/ModifierManager.gd"
MissionManager="*res://scripts/managers/MissionManager.gd"
SecretRealmManager="*res://scripts/managers/SecretRealmManager.gd"
ResourceSiteManager="*res://scripts/managers/ResourceSiteManager.gd"
TerritoryManager="*res://scripts/managers/TerritoryManager.gd"
DiplomacyManager="*res://scripts/managers/DiplomacyManager.gd"
BattleManager="*res://scripts/managers/BattleManager.gd"
WarManager="*res://scripts/managers/WarManager.gd"
InventoryManager="*res://scripts/managers/InventoryManager.gd"
CraftingManager="*res://scripts/managers/CraftingManager.gd"
MarketManager="*res://scripts/managers/MarketManager.gd"
StoryGoalManager="*res://scripts/managers/StoryGoalManager.gd"
TutorialManager="*res://scripts/managers/TutorialManager.gd"
SaveManager="*res://scripts/core/SaveManager.gd"
GameState="*res://scripts/core/GameState.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://assets/ui/wanzong_theme.tres"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
